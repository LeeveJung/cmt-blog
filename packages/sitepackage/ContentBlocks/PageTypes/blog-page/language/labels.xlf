      </trans-unit>
      <trans-unit id="publish_date.label">
        <source>Publish Date</source>
      </trans-unit>
      <trans-unit id="publish_date.description">
        <source>The date displayed to readers as the publication date. Independent of the technical creation date.</source>
      </trans-unit>
      <trans-unit id="teaser_image.label">
        <source>Teaser Image</source>
      </trans-unit>
      <trans-unit id="teaser_image.description">
        <source>Image shown in blog listing views. Use the crop variants to define the visible area for 16:9 (card) and 1:1 (square) formats.</source>
      </trans-unit>
