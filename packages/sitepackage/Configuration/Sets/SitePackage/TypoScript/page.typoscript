##############
#### PAGE ####
##############



page = PAGE
page {
    typeNum = 0
    shortcutIcon = EXT:sitepackage/Resources/Public/Icons/favicon.ico

    headerData {
        10 = TEXT
        10.value = <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        20 = TEXT
        20.value = <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
        30 = TEXT
        30.value = <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
        40 = TEXT
        40.value = <link rel="manifest" href="/site.webmanifest">
    }

    bodyTagAdd = class="flex flex-col min-h-screen"

    10 = PAGEVIEW
    10 {
        paths {
            0 = EXT:sitepackage/Resources/Private/PageView/
            1 = {$page.pageview.paths}
        }
        dataProcessing {
            5 = Brauer\Sitepackage\DataProcessing\WebSiteProcessor
            5.websiteDescription = {$website.description}

            10 = files
            10 {
                references.fieldName = media
            }
            20 = menu
            20 {
                levels = 2
                includeSpacer = 1
                as = mainnavigation
            }
            30 = page-content

            40 = menu
            40 {
                special = directory
                special.value = 23
                as = footernavigation
            }

            70 = language-menu
            70 {
                languages = auto
                as = languagenavigation
            }

            80 = menu
            80 {
                special = rootline
                special.range = 0|-1
                as = breadcrumb
            }
        }
    }

    meta {
        viewport = {$page.meta.viewport}
        robots = {$page.meta.robots}
        apple-mobile-web-app-capable = {$page.meta.apple-mobile-web-app-capable}

        X-UA-Compatible = {$page.meta.compatible}
        X-UA-Compatible {
            attribute = http-equiv
        }

        og:locale = de_DE
        og:locale {
            attribute = property
        }

        og:type = website
        og:type {
            attribute = property
        }

        og:url.data = getIndpEnv:TYPO3_REQUEST_URL
        og:url.attribute = property

        og:site_name = Leben mit CMT
        og:site_name {
            attribute = property
        }
    }

    includeCSSLibs {

    }

    includeCSS {
        bootstrap >
        nscomment_FontAwesomeCss >
    }

    includeJSLibs {

    }

    includeJS {
        nscomment_Minjs >
    }

    includeJSFooterlibs {
        bootstrap >
    }

    includeJSFooter {
        nscomment_CustomJS >
    }
}

[traverse(page, "doktype") == 1775660402]
page.10.dataProcessing {
    50 = files
    50 {
        references {
            table = pages
            fieldName = brauer_teaser_image
        }
        as = blogTeaserImage
    }
    60 = Brauer\Sitepackage\DataProcessing\BlogPageProcessor
    60.authorName = {$author.name}
}
[END]

[siteLanguage("hreflang") == "en"]
page.10.dataProcessing.5.websiteDescription = {$website.descriptionEn}
page.meta.og:locale = en_US
page.meta.og:site_name = My life with CMT
[END]

[traverse(page, "doktype") == 1775660402]
page.meta.og:type = article
[END]

[traverse(page, "slug") == "/ueber-mich" || traverse(page, "slug") == "/about-me"]
page.meta.og:type = profile
page.10.dataProcessing {
    90 = Brauer\Sitepackage\DataProcessing\AboutPageProcessor
    90.authorName = {$author.name}
    90.authorDescription = {$author.description}
    90.authorInstagramUrl = {$author.instagramUrl}
    90.authorLinkedInUrl = {$author.linkedInUrl}
    90.authorKnowsAbout = {$author.knowsAbout}
    90.authorImageFalUid = {$author.imageFalUid}
    90.authorImageAlt = {$author.imageAlt}
}
[END]

[siteLanguage("hreflang") == "en" && (traverse(page, "slug") == "/ueber-mich" || traverse(page, "slug") == "/about-me")]
page.10.dataProcessing.90.authorDescription = {$author.descriptionEn}
page.10.dataProcessing.90.authorKnowsAbout = {$author.knowsAboutEn}
page.10.dataProcessing.90.authorImageAlt = {$author.imageAltEn}
[END]

